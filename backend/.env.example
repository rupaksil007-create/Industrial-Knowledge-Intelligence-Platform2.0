# Project Settings
PROJECT_NAME="Industrial Knowledge Intelligence Platform"

# Vector Store Path
# Relative path is fine, will be resolved by the backend app
CHROMA_PERSIST_DIR="./data/chroma_db"
UPLOAD_DIR="./data/uploaded_documents"

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Providers
# EMBEDDING_PROVIDER options:
# - "chroma": local ONNX all-MiniLM-L6-v2 model (default, no API key required)
# - "openai": OpenAI text-embedding-3-small
# - "gemini": Google Generative AI embedding-001
EMBEDDING_PROVIDER="chroma"

# LLM_PROVIDER options:
# - "mock": local offline keyword scanner (default, no API key required)
# - "openai": OpenAI gpt-4o-mini
# - "gemini": Google Gemini 3.5 Flash
LLM_PROVIDER="gemini"

# API Keys (Provide these if using openai or gemini providers)
OPENAI_API_KEY="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"
GEMINI_API_KEY="AQ.Ab8RN6JUDGdoZlUFvqWGuefbQnVP8yHi0vCSsWNQ_ePEPWOQGA"

# Custom Models (optional)
OPENAI_MODEL="gpt-4o-mini"
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
